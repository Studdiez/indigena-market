# Core runtime
NODE_ENV=production
PORT=5000
MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>/<db>?retryWrites=true&w=majority

# API security/network
TRUST_PROXY=true
CORS_ORIGINS=https://app.indigena.global,https://admin.indigena.global
REQUEST_TIMEOUT_MS=30000

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120
RATE_LIMIT_PREFIX=indigena-api
REDIS_URL=redis://:<password>@<host>:6379/0
RATE_LIMIT_TIERS_JSON=[{"name":"admin","match":"/api/admin","windowMs":60000,"maxRequests":60,"circuitTriggerCount":50,"circuitOpenMs":30000},{"name":"mutations","match":"/api","methods":["POST","PUT","PATCH","DELETE"],"windowMs":60000,"maxRequests":90,"circuitTriggerCount":80,"circuitOpenMs":30000},{"name":"default","match":"/api","windowMs":60000,"maxRequests":150,"circuitTriggerCount":120,"circuitOpenMs":20000}]

# Observability and signal hooks
REQUEST_LOG_ENABLED=true
LOG_SHIP_ENDPOINT=https://logs.example.com/ingest
LOG_SHIP_TOKEN=<token>
OPS_SIGNAL_WEBHOOK_URL=https://hooks.example.com/ops
OPS_SIGNAL_ERROR_RATE_WINDOW_MS=60000
OPS_SIGNAL_MIN_REQUESTS=50
OPS_SIGNAL_ERROR_RATE_THRESHOLD=0.15
OPS_SIGNAL_COOLDOWN_MS=120000

# Marketplace frontend API bridge
NEXT_PUBLIC_API_BASE_URL=https://api.indigena.global/api
