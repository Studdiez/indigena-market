# Production-required core
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
INDIGENA_WALLET_SESSION_SECRET=
SUPABASE_ENTERPRISE_CONTRACT_BUCKET=enterprise-contracts

# Production-required Pillar 9
ADVOCACY_PAYMENT_WEBHOOK_SECRET=
SUPABASE_ADVOCACY_EVIDENCE_BUCKET=advocacy-evidence
ADVOCACY_ADMIN_WALLETS=
ADVOCACY_LEGAL_OPS_WALLETS=

# Production-required Pillar 10
MATERIALS_TOOLS_PAYMENT_WEBHOOK_SECRET=
SUPABASE_MATERIALS_TOOLS_PROOF_BUCKET=materials-tools-proof
SUPABASE_CREATOR_PROFILE_MEDIA_BUCKET=creator-profile-media
MARKETING_PAYMENT_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_MARKETING_WEBHOOK_SECRET=

# Normal app runtime
# Internal Next/Supabase API is the default app mode.
NEXT_PUBLIC_USE_APP_API=true

# Optional integrations / alternate routing
# Only set this when pointing the frontend at an external API host.
NEXT_PUBLIC_API_BASE_URL=

# Local dev / demo-only flags
# Keep these false for production-like runs.
ADVOCACY_ALLOW_DEV_HEADER_AUTH=true
NEXT_PUBLIC_ENABLE_MOCK_FALLBACK=false
NEXT_PUBLIC_ALLOW_TOURISM_MOCKS=false
ALLOW_RUNTIME_PERSISTENCE_IN_PRODUCTION=false
